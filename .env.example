# =============================================================================
# Application
# =============================================================================
APP_NAME="ATS Recruitment Platform"
APP_ENV=development           # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ats_db

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# =============================================================================
# SMTP
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="ATS Platform"
SMTP_FROM_EMAIL=no-reply@yourplatform.com
SMTP_TLS=true

# =============================================================================
# File Storage
# =============================================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_APPLY=20/minute
